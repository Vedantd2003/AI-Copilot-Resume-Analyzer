PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ai_career_copilot

# JWT Secrets (use strong random strings in production)
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Verification Token
EMAIL_VERIFY_SECRET=your_email_verify_secret_key

# Password Reset Token
PASSWORD_RESET_SECRET=your_password_reset_secret_key

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Email (Gmail)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password_here
EMAIL_FROM=AI Career Copilot <your_gmail@gmail.com>

# Frontend URL (for CORS and email links)
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
